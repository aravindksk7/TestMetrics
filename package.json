{
  "name": "xray-test-metrics",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/server.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "node server/server.js",
    "migrate": "node server/config/migrate.js",
    "seed": "node database/seeds/seed.js",
    "verify-kpis": "node database/seeds/lib/verifyKpis.js",
    "ingest:xlsx": "node server/ingestion/index.js --source=xlsx",
    "ingest:xray": "node server/ingestion/index.js --source=xray"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
