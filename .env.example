# App
PORT=3500
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/xray_metrics

# Ingestion: Xray Cloud (use these OR Server/DC below, not both)
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
JIRA_BASE_URL=https://yourorg.atlassian.net

# Ingestion: Xray Server / Data Center
# JIRA_API_TOKEN=
# JIRA_USER_EMAIL=
# JIRA_BASE_URL=https://jira.yourorg.com

# Spreadsheet ingestion
XLSX_FILE_PATH=./Xray_TestMetrics_PBI_BuildPack_2.xlsx

# Auto-ingest schedule (cron syntax, optional)
# INGESTION_CRON=0 * * * *
